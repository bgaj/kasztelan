%tr
  %td.title
    = image_tag player.image.image.small_thumb.url
  %td
    = player.name
  %td
    = player.surname
  %td
    = player.number
  %td
    = player.position_name
  %td
    =link_to "Usuń", admin_player_path(player), method: :delete
    =link_to "Edytuj", edit_admin_player_path(player)