<!DOCTYPE html>
<html>
  <head>
    <title>Kasztelan Rozprza</title>
    <%= csrf_meta_tags %>

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">
    <%= stylesheet_link_tag    'application', media: 'all'%>
    <%= javascript_include_tag 'application' %>
    <!-- Following will make the react components availabe to our layout -->
    <%= javascript_pack_tag 'front/index' %>
    <%= stylesheet_pack_tag 'front/assets/stylesheets/app' %>
    <link rel="manifest" href="<%= asset_path 'favicon/manifest.json'%>>">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="msapplication-TileImage" content="<%= asset_path 'favicon/ms-icon-144x144.png'%>">
    <meta name="theme-color" content="#ffffff">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
  </head>

  <body>
    <%= yield %>
  </body>
</html>
